FROM node:22-bookworm-slim

# System deps for Playwright browsers + Hermes build requirements
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git python3 python3-pip python3-venv python3-dev python3-yaml \
    build-essential libffi-dev sqlite3 \
    # Playwright Chromium deps
    libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
    libxkbcommon0 libxcomposite1 libxdamage1 libxrandr2 libgbm1 \
    libpango-1.0-0 libcairo2 libasound2 libxshmfence1 \
    fonts-liberation libappindicator3-1 xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# ── Install Hermes Agent ──────────────────────────────────────────────────
# Install uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh 2>/dev/null \
    && ln -sf /root/.local/bin/uv /usr/local/bin/uv

# Clone Hermes from Euraika-Labs fork at the pinned tag and install
ARG HERMES_REPO=https://github.com/Euraika-Labs/hermes-agent.git
ARG HERMES_TAG=pan-v0.7.0
RUN git clone --depth 1 --branch ${HERMES_TAG} ${HERMES_REPO} /opt/hermes-agent \
    && cd /opt/hermes-agent \
    && uv venv venv --python 3.11 \
    && VIRTUAL_ENV=/opt/hermes-agent/venv uv pip install -e "." \
    && ln -sf /opt/hermes-agent/venv/bin/hermes /usr/local/bin/hermes

# Verify hermes is available
RUN hermes --version

# ── Build Pan UI ──────────────────────────────────────────────────────────
WORKDIR /app

# Copy package files first for layer caching
COPY package.json package-lock.json* ./

# Install deps
RUN npm ci --ignore-scripts 2>/dev/null || npm install

# Copy everything
COPY . .

# Install Playwright browsers
RUN npx playwright install chromium 2>/dev/null || true

# Build
ENV HERMES_MOCK_MODE=true
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# Copy static assets for standalone
RUN cp -r .next/static .next/standalone/.next/static 2>/dev/null || true
RUN [ -d public ] && cp -r public .next/standalone/public || true

EXPOSE 3000

# Health check
HEALTHCHECK --interval=3s --timeout=3s --retries=10 \
    CMD curl -f http://localhost:3000/api/runtime/health || exit 1

ENV PORT=3000
ENV HOSTNAME=0.0.0.0
CMD ["node", ".next/standalone/server.js"]
